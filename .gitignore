# ════════════════════════════════════════
# BACKEND — Java / Spring Boot / Maven
# ════════════════════════════════════════

# Maven compiled output — never upload
Equitly_Backend/target/
Equitly_Backend/*.class
Equitly_Backend/*.jar
Equitly_Backend/*.war

# Uploaded receipt files
Equitly_Backend/uploads/

# Production properties — contains DB passwords
# Keep this secret — never upload to GitHub
Equitly_Backend/src/main/resources/application-prod.properties

# STS / Eclipse IDE files
Equitly_Backend/.settings/
Equitly_Backend/.classpath
Equitly_Backend/.project
Equitly_Backend/.sts4-cache/
Equitly_Backend/.factorypath

# IntelliJ IDEA
Equitly_Backend/.idea/
Equitly_Backend/*.iml
Equitly_Backend/*.iws
Equitly_Backend/*.ipr

# Logs
Equitly_Backend/logs/
Equitly_Backend/*.log

# ════════════════════════════════════════
# FRONTEND — React / Node.js / Vite
# ════════════════════════════════════════

# Node modules — never upload (400MB+)
Equitly_Frontend/node_modules/

# Build output — generated by npm run build
Equitly_Frontend/dist/
Equitly_Frontend/build/

# Environment files — contains API keys
# .env is okay to upload (has localhost URL)
# .env.production and .env.local are secret
Equitly_Frontend/.env.local
Equitly_Frontend/.env.production

# Vite cache
Equitly_Frontend/.vite/

# NPM logs
Equitly_Frontend/npm-debug.log*
Equitly_Frontend/yarn-debug.log*
Equitly_Frontend/yarn-error.log*
Equitly_Frontend/*.log

# ════════════════════════════════════════
# COMMON — Both folders
# ════════════════════════════════════════

# OS generated files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# Editor files
.vscode/
*.swp
*.swo
*~

# ════════════════════════════════════════
# WHAT IS UPLOADED TO GITHUB
# ════════════════════════════════════════
# ✅ Equitly_Backend/src/ — all Java source code
# ✅ Equitly_Backend/pom.xml — Maven dependencies
# ✅ Equitly_Backend/Dockerfile — for Render
# ✅ Equitly_Backend/mvnw — Maven wrapper
# ✅ Equitly_Backend/application.properties — local config
# ❌ Equitly_Backend/application-prod.properties — SECRET
# ❌ Equitly_Backend/target/ — compiled files
# ❌ Equitly_Backend/uploads/ — user files
#
# ✅ Equitly_Frontend/src/ — all React source code
# ✅ Equitly_Frontend/package.json — dependencies
# ✅ Equitly_Frontend/vite.config.js — Vite config
# ✅ Equitly_Frontend/netlify.toml — for Netlify
# ✅ Equitly_Frontend/.env — local API URL (safe)
# ❌ Equitly_Frontend/.env.production — SECRET
# ❌ Equitly_Frontend/node_modules/ — huge folder
# ❌ Equitly_Frontend/dist/ — build output